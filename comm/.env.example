# --- Firebase (Firestore) ---
# console.firebase.google.com → Project Settings → Service accounts → Generate new private key (JSON)
FIREBASE_PROJECT_ID="acttub-comm"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@acttub-comm.iam.gserviceaccount.com"
# 다운로드한 JSON 의 private_key 값. 개행은 \n 으로 이스케이프된 채로 한 줄 문자열로 넣을 것.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# Web SDK (브라우저 onSnapshot 구독용). Project Settings → General → Your apps → Web app config
NEXT_PUBLIC_FIREBASE_API_KEY="AIza..."
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="acttub-comm.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="acttub-comm"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="acttub-comm.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="123456789012"
NEXT_PUBLIC_FIREBASE_APP_ID="1:123456789012:web:abc123def456"

# --- Clerk (arch 와 같은 application 공유) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_XXXX"
CLERK_SECRET_KEY="sk_test_XXXX"
# comm 전용 webhook secret (배포 URL 받은 뒤 Clerk 대시보드에서 endpoint 등록 → secret 발급)
CLERK_WEBHOOK_SECRET="whsec_XXXX"

NEXT_PUBLIC_CLERK_SIGN_IN_URL="/community/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/community/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/community"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/community"
