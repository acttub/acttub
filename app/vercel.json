{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/archive/:path*", "destination": "https://acttub-archive.vercel.app/archive/:path*" },
    { "source": "/community/:path*", "destination": "https://acttub-comm.vercel.app/community/:path*" },
    { "source": "/excer/:path*", "destination": "https://acttub-excer.vercel.app/excer/:path*" },
    { "source": "/thea/:path*", "destination": "https://thea-zeta.vercel.app/thea/:path*" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/og/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
