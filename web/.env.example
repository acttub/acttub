# 카카오 개발자센터에서 발급받은 JavaScript 키
# https://developers.kakao.com/
NEXT_PUBLIC_KAKAO_APP_KEY=

# 배포 도메인 (OG 메타·카카오 공유의 절대 URL 베이스).
# 로컬 개발에서는 비워두면 window.location.origin 사용.
NEXT_PUBLIC_SITE_URL=

# Google Analytics 4 Measurement ID (예: G-XXXXXXXXXX).
# 비워두면 GA 스크립트를 로드하지 않습니다.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- 서버 전용 (Vercel Environment Variables, NEXT_PUBLIC_ 접두 X) ---
# 결과 메일 발송용 Resend API 키 (https://resend.com/api-keys)
RESEND_API_KEY=
# 발신 주소. 도메인 검증 전엔 onboarding@resend.dev 사용 가능
RESEND_FROM=ACTI <onboarding@resend.dev>
# 메일 본문 안의 링크에 쓰이는 절대 URL (서버용. NEXT_PUBLIC_SITE_URL 과 동일하게 맞추세요)
SITE_URL=
# (선택) 신청 이메일을 Google Sheet에 기록할 Apps Script Web App URL
# https://script.google.com/macros/s/.../exec
SHEETS_WEBHOOK_URL=

# coach 분석용 서버 키
GEMINI_API_KEY=

# Neon/Vercel Postgres 연결 문자열. 비워두면 로컬에서는 메모리 저장소를 사용합니다.
DATABASE_URL=

# Vercel Blob 업로드용 토큰. 비워두면 직접 업로드 API가 비활성화됩니다.
BLOB_READ_WRITE_TOKEN=
