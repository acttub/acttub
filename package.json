{
  "name": "acttub-monorepo",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "local": "corepack pnpm --dir web dev --host 127.0.0.1 --port 4000",
    "local:web": "corepack pnpm --dir web dev --host 127.0.0.1 --port 4000",
    "local:lan": "corepack pnpm --dir web dev --host 0.0.0.0 --port 4000",
    "local:coach": "corepack pnpm --dir coach dev --port 3004",
    "prod": "corepack pnpm prod:web && corepack pnpm prod:coach",
    "prod:web": "corepack pnpm --dir web build",
    "prod:coach": "corepack pnpm --dir coach build",
    "lint": "corepack pnpm --dir web lint && corepack pnpm --dir coach lint",
    "build": "corepack pnpm prod",
    "test": "corepack pnpm --dir web test",
    "verify": "corepack pnpm install --frozen-lockfile && corepack pnpm lint && corepack pnpm test && corepack pnpm prod"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@google/genai",
      "esbuild",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ]
  }
}
