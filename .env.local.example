# Copy to .env.local and fill in values

# Kakao Maps JavaScript SDK
NEXT_PUBLIC_KAKAO_MAP_KEY=

# Neon Postgres
DATABASE_URL=

# Vercel Blob (server-only; provided by Vercel automatically in deployment)
BLOB_READ_WRITE_TOKEN=

# Clerk (shared across acttub apps — keys from the same Clerk instance)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
