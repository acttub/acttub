# Set this on Vercel if the app is served from https://www.acttub.com/thea.
# Value: path segment WITHOUT leading/trailing slashes (e.g. `thea`, not `/thea/`).
# Leave unset or empty to serve from the domain root.
NEXT_PUBLIC_BASE_PATH=thea

# KOPIS (공연예술통합전산망) Open API service key.
# Get one at https://www.kopis.or.kr/por/cs/openapi/openApiInfo.do
# When unset, the app falls back to the curated list with no live schedule data.
KOPIS_API_KEY=
